---
// 代表ごあいさつ用のモノグラム図（顔写真の代わりとなる装飾カード）。
// 事実でない人物写真は用いず、ブランドのモチーフ（水滴＋葉）と
// 代表者名・サインで構成した意図的なグラフィックにしています。
interface Props {
  name: string;
  title: string;
}
const { name, title } = Astro.props;
---

<figure class="ceo-figure">
  <div class="ceo-card">
    <span class="ceo-en">REPRESENTATIVE</span>

    <div class="ceo-medallion">
      <div class="ceo-mark">
        <svg viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <linearGradient id="ceo-drop" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#2A86C0" /><stop offset="1" stop-color="#3aa0c8" />
            </linearGradient>
            <linearGradient id="ceo-leaf" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#98C727" /><stop offset="1" stop-color="#7fae1d" />
            </linearGradient>
          </defs>
          <path d="M44 22c14 18 22 29 22 40a22 22 0 0 1-44 0c0-11 8-22 22-40z" fill="url(#ceo-drop)" />
          <ellipse cx="37" cy="62" rx="5" ry="8" fill="#fff" opacity=".35" />
          <path d="M64 28c11-6 24-4 24-4s1 13-7 20-18 5-18 5 1-15 1-21z" fill="url(#ceo-leaf)" />
          <path d="M68 44c6-7 14-12 19-14" stroke="#fff" stroke-width="2.4" stroke-linecap="round" opacity=".55" />
        </svg>
      </div>
    </div>

    <p class="ceo-title">{title}</p>
    <p class="ceo-name">{name}</p>

    <svg class="ceo-sign" viewBox="0 0 200 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path
        d="M14 34c10-14 18-20 22-18s-6 22 2 24 18-20 26-22 0 18 8 18 16-12 24-16 22-6 28-2 18 8 28 6"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        opacity=".45"
      />
    </svg>
  </div>
</figure>

<style>
  .ceo-figure {
    margin: 0;
  }
  .ceo-card {
    position: relative;
    background: linear-gradient(165deg, #eef6fb 0%, #ffffff 70%);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    padding: clamp(32px, 4vw, 44px) clamp(24px, 3vw, 36px);
    text-align: center;
    overflow: hidden;
  }
  .ceo-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 6px;
    background: var(--grad);
  }
  .ceo-en {
    display: block;
    font-family: var(--font-en, inherit);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--blue);
    margin-bottom: 1.1em;
  }
  .ceo-medallion {
    width: 132px;
    height: 132px;
    margin: 0 auto 1.1em;
    border-radius: 50%;
    background: var(--grad);
    padding: 5px;
    box-shadow: 0 18px 36px -18px rgba(42, 134, 192, 0.6);
  }
  .ceo-mark {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ceo-mark svg {
    width: 58%;
    height: 58%;
  }
  .ceo-title {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 0;
  }
  .ceo-name {
    color: var(--ink);
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    margin: 0.15em 0 0.2em;
  }
  .ceo-sign {
    width: 150px;
    height: auto;
    color: var(--blue-d);
  }
</style>
