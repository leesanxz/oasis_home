---
// オアシス情報システムズ ロゴ（元の logo-full.png：OiSマーク＋社名／余白トリミング版）
import { url } from '../utils/url';
interface Props {
  markSize?: number; // 表示高さ(px)
}
const { markSize = 62 } = Astro.props;
---

<img
  class="oasis-logo"
  src={url('/assets/logo-full-trim.png')}
  alt="株式会社オアシス情報システムズ"
  style={`height:${markSize}px`}
  width="430"
  height="267"
/>

<style>
  .oasis-logo {
    display: block;
    width: auto;
    max-width: 100%;
  }
</style>
