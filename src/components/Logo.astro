---
// オアシス情報システムズ ロゴ（元のOiSマーク＋読める社名／縦並び）
import { url } from '../utils/url';
interface Props {
  showWord?: boolean; // 社名テキストを表示
  markSize?: number; // OiSマークの高さ(px)
}
const { showWord = true, markSize = 40 } = Astro.props;
---

<span class="oasis-logo">
  <img class="ol-mark" src={url('/assets/logo-ois.png')} alt="オアシス情報システムズ" style={`height:${markSize}px`} />
  {showWord && <span class="ol-name">株式会社オアシス情報システムズ</span>}
</span>

<style>
  .oasis-logo {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    line-height: 1;
  }
  .ol-mark {
    width: auto;
    display: block;
  }
  .ol-name {
    font-family: 'Noto Sans JP', 'Hiragino Sans', sans-serif;
    color: #1c86c4;
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  @media (max-width: 420px) {
    .ol-name { font-size: 0.72rem; letter-spacing: 0.01em; }
  }
</style>
