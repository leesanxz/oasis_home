---
// 「私たちについて」用の自作SVGイラスト（オアシス＝水と緑＋成長の抽象表現）
---
<svg class="about-art" viewBox="0 0 480 420" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="オアシスのイメージイラスト">
  <defs>
    <linearGradient id="ab-g1" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#2A86C0"/><stop offset="1" stop-color="#3aa0c8"/>
    </linearGradient>
    <linearGradient id="ab-g2" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#98C727"/><stop offset="1" stop-color="#7fae1d"/>
    </linearGradient>
    <linearGradient id="ab-g3" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#eef6fb"/><stop offset="1" stop-color="#dceefa"/>
    </linearGradient>
  </defs>

  <!-- soft backdrop -->
  <circle cx="250" cy="200" r="180" fill="url(#ab-g3)"/>

  <!-- big water drop -->
  <path d="M250 60c46 60 74 96 74 134a74 74 0 0 1-148 0c0-38 28-74 74-134z" fill="url(#ab-g1)"/>
  <path d="M250 60c46 60 74 96 74 134a74 74 0 0 1-148 0c0-38 28-74 74-134z" fill="#fff" opacity=".08"/>
  <!-- drop highlight -->
  <ellipse cx="226" cy="200" rx="16" ry="26" fill="#fff" opacity=".35"/>

  <!-- leaf -->
  <path d="M318 96c34-20 78-14 78-14s4 44-22 66-58 16-58 16 4-50 2-68z" fill="url(#ab-g2)"/>
  <path d="M330 150c18-22 44-40 60-46" stroke="#fff" stroke-width="3" stroke-linecap="round" opacity=".5"/>

  <!-- floating data cards -->
  <g>
    <rect x="60" y="150" width="118" height="78" rx="14" fill="#fff" stroke="#e6edf3"/>
    <rect x="76" y="170" width="60" height="9" rx="4.5" fill="#cfe3f1"/>
    <rect x="76" y="188" width="86" height="9" rx="4.5" fill="#e6edf3"/>
    <rect x="76" y="206" width="44" height="9" rx="4.5" fill="#cde3a8"/>
  </g>
  <g>
    <rect x="300" y="250" width="120" height="84" rx="14" fill="#fff" stroke="#e6edf3"/>
    <circle cx="326" cy="276" r="12" fill="url(#ab-g1)"/>
    <rect x="346" y="270" width="58" height="8" rx="4" fill="#e6edf3"/>
    <rect x="316" y="300" width="88" height="8" rx="4" fill="#e6edf3"/>
    <rect x="316" y="316" width="56" height="8" rx="4" fill="#cde3a8"/>
  </g>

  <!-- connecting dots -->
  <circle cx="150" cy="300" r="9" fill="url(#ab-g2)"/>
  <circle cx="392" cy="150" r="7" fill="url(#ab-g1)"/>
  <path d="M150 300 Q200 340 250 320" stroke="#cfe3f1" stroke-width="2.5" stroke-dasharray="3 7" stroke-linecap="round"/>

  <!-- ground wave -->
  <path d="M70 348q90 28 180 0t180 0" stroke="url(#ab-g1)" stroke-width="4" stroke-linecap="round" opacity=".5"/>
</svg>

<style>
  .about-art {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
