---
import Base from '../layouts/Base.astro';
import { SITE, COMPANY, SERVICES } from '../data/site';

const icons: Record<string, string> = {
  code: '<path d="M9 8l-5 4 5 4M15 8l5 4-5 4" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>',
  cloud:
    '<path d="M7 18a4 4 0 0 1 .4-8 5.5 5.5 0 0 1 10.6 1.3A3.6 3.6 0 0 1 17.5 18z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>',
  people:
    '<circle cx="9" cy="9" r="3" fill="none" stroke="currentColor" stroke-width="2.2"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0M16 7a3 3 0 0 1 0 6M16.5 19a5.5 5.5 0 0 0-2-4.3" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>',
};

const companyRows: { th: string; td: string }[] = [
  { th: '会社名', td: COMPANY.name },
  { th: '設立', td: COMPANY.established },
  { th: '資本金', td: COMPANY.capital },
  {
    th: '代表者',
    td: COMPANY.representatives.map((r) => `${r.title} ${r.name}`).join('　'),
  },
  { th: '所在地', td: `〒${COMPANY.postalCode}　${COMPANY.address}` },
  { th: '電話番号', td: COMPANY.tel },
  { th: '法人番号', td: COMPANY.corporateNumber },
  {
    th: '事業内容',
    td: SERVICES.map((s) => s.title).join(' ／ '),
  },
];
---

<Base>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <span class="blob blob-1"></span>
      <span class="blob blob-2"></span>
    </div>
    <div class="container hero-inner">
      <p class="hero-eyebrow">{SITE.nameEn}</p>
      <h1>
        情報技術で、<br />ビジネスに<span class="hl">潤い</span>を。
      </h1>
      <p class="hero-lead">
        ソフトウェア開発の受託、クラウドサービスの構築・提案、人材リソースサービス。<br />
        オアシス情報システムズは、お客様のビジネスを技術で支えるITパートナーです。
      </p>
      <div class="hero-actions">
        <a href="#services" class="btn btn--primary">事業内容を見る</a>
        <a href="#company" class="btn btn--outline">会社概要</a>
      </div>
    </div>
    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,64 C240,120 480,16 720,40 C960,64 1200,120 1440,72 L1440,120 L0,120 Z" fill="#ffffff" />
      </svg>
    </div>
  </section>

  <!-- ===================== ABOUT (intro) ===================== -->
  <section class="section" id="about">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">ABOUT US</span>
        <h2>“オアシス”であり続けるために</h2>
        <p class="lead">
          砂漠の中の水と緑のように、企業活動に欠かせない潤いを。<br />
          私たちは確かな技術と人で、お客様の事業の成長を支えます。
        </p>
      </div>
      <div class="about-grid">
        <div class="about-card card reveal">
          <span class="about-num">01</span>
          <h3>確かな開発力</h3>
          <p>要件定義から設計・開発・保守まで一貫対応。お客様の課題に寄り添い、最適なシステムを形にします。</p>
        </div>
        <div class="about-card card reveal">
          <span class="about-num">02</span>
          <h3>クラウド活用</h3>
          <p>クラウド環境の構築・提案を通じて、柔軟でコスト効率の高いITインフラの実現を支援します。</p>
        </div>
        <div class="about-card card reveal">
          <span class="about-num">03</span>
          <h3>人材ネットワーク</h3>
          <p>豊富な技術者ネットワークを活かし、プロジェクトに最適なエンジニアをご紹介します。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="section section--soft" id="services">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">SERVICES</span>
        <h2>事業内容</h2>
        <p class="lead">3つのサービスで、お客様のビジネスを多角的に支援します。</p>
      </div>
      <div class="grid grid-3">
        {SERVICES.map((s) => (
          <article class="service-card card reveal">
            <span class="service-icon">
              <svg viewBox="0 0 24 24" width="28" height="28" set:html={icons[s.icon]} />
            </span>
            <h3>{s.title}</h3>
            <p>{s.summary}</p>
            <ul>
              {s.points.map((p) => <li>{p}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== COMPANY ===================== -->
  <section class="section" id="company">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">COMPANY</span>
        <h2>会社概要</h2>
      </div>
      <div class="company-wrap reveal">
        <table class="company-table">
          <tbody>
            {companyRows.map((r) => (
              <tr>
                <th scope="row">{r.th}</th>
                <td>{r.td}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="company-more">
          <a href="/company/history/" class="btn btn--outline">会社沿革を見る</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== CONTACT / RECRUIT CTA ===================== -->
  <section class="section section--blue" id="contact">
    <div class="container contact-inner reveal">
      <span class="eyebrow">CONTACT &amp; RECRUIT</span>
      <h2>一緒に、未来をつくる仲間を募集しています</h2>
      <p>
        当社では新しい仲間を募集しています。<br />
        ご応募・お問い合わせはオンライン応募フォームよりお気軽にどうぞ。
      </p>
      <div class="contact-actions">
        <a href="/recruit_top/subscription/" class="btn btn--primary">オンライン応募</a>
        <a href="/recruit_top/" class="btn btn--ghost">採用情報を見る</a>
      </div>
      <p class="contact-tel">
        お電話でのお問い合わせ：<a href={`tel:${COMPANY.tel.replaceAll('-', '')}`}>{COMPANY.tel}</a>
      </p>
    </div>
  </section>
</Base>

<style>
  /* ---- hero ---- */
  .hero {
    position: relative;
    background: linear-gradient(135deg, #2a86c0 0%, #1f6a9b 55%, #195677 100%);
    color: #fff;
    padding-top: calc(var(--header-h) + clamp(56px, 11vw, 120px));
    padding-bottom: clamp(90px, 14vw, 170px);
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(10px);
    opacity: 0.5;
  }
  .blob-1 {
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(152, 199, 39, 0.55), transparent 70%);
    top: -120px;
    right: -80px;
  }
  .blob-2 {
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.25), transparent 70%);
    bottom: -60px;
    left: -100px;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .hero-eyebrow {
    letter-spacing: 0.28em;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--green);
    margin-bottom: 1.2em;
  }
  .hero h1 {
    color: #fff;
    font-size: clamp(2.1rem, 6vw, 3.8rem);
    line-height: 1.3;
    letter-spacing: 0.02em;
  }
  .hero h1 .hl {
    color: var(--green);
  }
  .hero-lead {
    margin: 1.6em auto 0;
    max-width: 640px;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.96rem, 2vw, 1.1rem);
  }
  .hero-actions {
    margin-top: 2.4em;
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .hero-wave {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    line-height: 0;
  }
  .hero-wave svg {
    width: 100%;
    height: clamp(60px, 9vw, 120px);
    display: block;
  }

  /* ---- about ---- */
  .about-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 3vw, 30px);
  }
  .about-card {
    padding: 36px 30px;
    position: relative;
    overflow: hidden;
  }
  .about-num {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--bg-blue-soft);
    line-height: 1;
    display: block;
    margin-bottom: 0.2em;
  }
  .about-card h3 {
    color: var(--blue-dark);
    margin-bottom: 0.5em;
  }
  .about-card p {
    color: var(--ink-soft);
    margin: 0;
    font-size: 0.96rem;
  }

  /* ---- services ---- */
  .service-card {
    padding: 38px 32px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }
  .service-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 16px;
    background: var(--bg-blue-soft);
    color: var(--blue);
    margin-bottom: 1em;
  }
  .service-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.6em;
  }
  .service-card p {
    color: var(--ink-soft);
    font-size: 0.96rem;
  }
  .service-card ul {
    margin: 1.2em 0 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--line);
    padding-top: 1.1em;
  }
  .service-card li {
    position: relative;
    padding-left: 1.5em;
    margin-bottom: 0.5em;
    color: var(--ink-soft);
    font-size: 0.92rem;
  }
  .service-card li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
  }

  /* ---- company ---- */
  .company-wrap {
    max-width: 820px;
    margin-inline: auto;
  }
  .company-table {
    width: 100%;
    border-collapse: collapse;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .company-table th,
  .company-table td {
    padding: 1.05em 1.4em;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--line);
    font-size: 0.97rem;
  }
  .company-table tr:last-child th,
  .company-table tr:last-child td {
    border-bottom: none;
  }
  .company-table th {
    width: 32%;
    background: var(--bg-soft);
    color: var(--blue-dark);
    font-weight: 700;
    white-space: nowrap;
  }
  .company-more {
    margin-top: 1.8em;
    text-align: center;
  }
  @media (max-width: 640px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .company-table th {
      width: 38%;
      white-space: normal;
    }
  }

  /* ---- contact ---- */
  .contact-inner {
    text-align: center;
    max-width: 720px;
  }
  .contact-inner .eyebrow {
    display: inline-block;
    letter-spacing: 0.22em;
    font-weight: 700;
    color: var(--green);
    font-size: 0.82rem;
    margin-bottom: 1em;
  }
  .contact-inner h2 {
    color: #fff;
    font-size: clamp(1.5rem, 3.4vw, 2.2rem);
  }
  .contact-inner p {
    color: rgba(255, 255, 255, 0.9);
    margin-top: 1em;
  }
  .contact-actions {
    margin-top: 2em;
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .contact-tel {
    margin-top: 1.8em;
    font-size: 0.95rem;
  }
  .contact-tel a {
    color: #fff;
    font-weight: 700;
    text-decoration: underline;
  }
</style>
