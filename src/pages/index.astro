---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import HeroArt from '../components/HeroArt.astro';
import AboutArt from '../components/AboutArt.astro';
import CeoFigure from '../components/CeoFigure.astro';
import LogoMark from '../components/LogoMark.astro';
import {
  COMPANY, SERVICES, STATS, STRENGTHS, PROCESS, TECH_GROUPS, PHILOSOPHY, CEO_MESSAGE,
} from '../data/site';
import { url } from '../utils/url';

// 地図（Googleマップ。APIキー不要の埋め込み＋外部リンク）
const mapQuery = encodeURIComponent(`${COMPANY.addressLine1} ${COMPANY.addressLine2}`);
const mapEmbed = `https://maps.google.com/maps?q=${mapQuery}&z=16&hl=ja&output=embed`;
const mapLink = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;

const serviceIcons: Record<string, string> = {
  software: 'code',
  cloud: 'cloud',
  resource: 'people',
};

const companyRows: { th: string; td: string }[] = [
  { th: '会社名', td: COMPANY.name },
  { th: '設立', td: COMPANY.established },
  { th: '資本金', td: COMPANY.capital },
  { th: '代表者', td: COMPANY.representatives.map((r) => `${r.title} ${r.name}`).join('　') },
  { th: '所在地', td: `〒${COMPANY.postalCode}　${COMPANY.address}` },
  { th: '電話番号', td: COMPANY.tel },
  { th: '法人番号', td: COMPANY.corporateNumber },
  { th: '事業内容', td: SERVICES.map((s) => s.title).join(' ／ ') },
];
---

<Base>
  <!-- ===================== HERO ===================== -->
  <section class="hero dotgrid">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="chip"><LogoMark size={24} tone="gradient" title="株式会社オアシス情報システムズ" />株式会社<span class="grad-text">オアシス情報システムズ</span></span>
        <h1>情報技術で、<br />ビジネスに<span class="grad-text">潤い</span>を。</h1>
        <p class="hero-lead">
          ソフトウェア開発・クラウド・人材リソース。3つの力で、お客様の事業に確かな成長の源泉を届けるITパートナーです。
        </p>
        <div class="hero-actions">
          <a href="#services" class="btn btn--grad">事業内容を見る<Icon name="arrow" size={18} /></a>
          <a href="#company" class="btn btn--outline">会社情報</a>
          {/* ページ内アンカーは base 不要 */}
        </div>
        <ul class="hero-mini">
          <li><Icon name="check" size={16} /> <b>2017年</b>設立</li>
          <li><Icon name="check" size={16} /> 東京・<b>神保町</b></li>
          <li><Icon name="check" size={16} /> <b>ワンストップ</b>対応</li>
        </ul>
      </div>
      <div class="hero-visual reveal" data-delay="1">
        <HeroArt />
      </div>
    </div>
  </section>

  <!-- ===================== STATS ===================== -->
  <section class="stats">
    <div class="container stats-grid">
      {STATS.map((s) => (
        <div class="stat reveal">
          <div class="n">{s.value}<em>{s.unit}</em></div>
          <div class="l">{s.label}</div>
          <div class="note">{s.note}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===================== ABOUT ===================== -->
  <section class="section" id="about">
    <div class="container about-grid">
      <div class="about-art-wrap reveal">
        <AboutArt />
      </div>
      <div class="about-copy reveal" data-delay="1">
        <span class="eyebrow">ABOUT US</span>
        <h2>“オアシス”で<br />あり続けるために。</h2>
        <p>
          砂漠の中の水と緑のように、企業活動に欠かせない潤いを。<br />
          私たちオアシス情報システムズは、確かな技術と人の力で、お客様の事業の成長を支えるITパートナーです。
        </p>
        <p>
          ソフトウェア開発・クラウド・人材リソースの3領域を提供し、上流の提案から開発・運用まで切れ目なく伴走。長く寄り添える関係づくりを大切にしています。
        </p>
        <div class="about-points">
          <div><b>確かな開発力</b><span>提案・設計から運用保守まで一貫対応</span></div>
          <div><b>クラウド活用</b><span>柔軟でコスト効率の高い基盤を実現</span></div>
          <div><b>人材ネットワーク</b><span>最適なエンジニアで開発を支援</span></div>
        </div>
        <p class="about-more">
          <a href="#philosophy" class="btn btn--grad">会社理念を見る<Icon name="arrow" size={18} /></a>
          {/* ページ内アンカーは base 不要 */}
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== PHILOSOPHY（会社理念） ===================== -->
  <section class="section section--soft" id="philosophy">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">PHILOSOPHY</span>
        <h2>会社理念</h2>
        <p class="lead">{PHILOSOPHY.lead}</p>
      </div>
      <ul class="philosophy-list">
        {PHILOSOPHY.items.map((p, i) => (
          <li class="philosophy-item reveal" data-delay={i}>
            <span class="ph-num">{String(i + 1).padStart(2, '0')}</span>
            <div class="ph-body">
              <h3>{p.title}</h3>
              <p>{p.text}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===================== MESSAGE（代表ごあいさつ） ===================== -->
  <section class="section" id="message">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">MESSAGE</span>
        <h2>代表ご挨拶</h2>
      </div>
      <div class="message-grid">
        <div class="message-figure reveal">
          <CeoFigure name={CEO_MESSAGE.name} title={CEO_MESSAGE.title} />
        </div>
        <div class="message-card reveal" data-delay="1">
          {CEO_MESSAGE.paragraphs.map((p) => <p>{p}</p>)}
          <p class="message-sign">
            {CEO_MESSAGE.title}　<strong>{CEO_MESSAGE.name}</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="section section--soft" id="services">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">SERVICES</span>
        <h2>事業内容</h2>
        <p class="lead">3つのサービスで、お客様のビジネスを多角的に支援します。</p>
      </div>
      <div class="grid grid-3">
        {SERVICES.map((s, i) => (
          <article class="service-card reveal" data-delay={i}>
            <span class="svc-no">{s.no}</span>
            <span class="svc-tile"><Icon name={serviceIcons[s.id]} size={30} /></span>
            <h3>{s.title}</h3>
            <div class="svc-en">{s.titleEn}</div>
            <p>{s.summary}</p>
            <ul>
              {s.points.map((p) => <li>{p}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== STRENGTHS ===================== -->
  <section class="section" id="strengths">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">OUR STRENGTHS</span>
        <h2>選ばれる理由</h2>
        <p class="lead">オアシス情報システムズが大切にしている3つの強み。</p>
      </div>
      <div class="grid grid-3">
        {STRENGTHS.map((s, i) => (
          <div class="strength-card reveal" data-delay={i}>
            <span class="st-icon"><Icon name={s.icon} size={26} /></span>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== PROCESS ===================== -->
  <section class="section section--soft" id="process">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">FLOW</span>
        <h2>ご依頼から運用までの流れ</h2>
        <p class="lead">ご相談から運用保守まで、安心して進められる流れです。</p>
      </div>
      <ol class="process">
        {PROCESS.map((p) => (
          <li class="process-step reveal">
            <span class="ps-no">{p.no}</span>
            <h3>{p.title}</h3>
            <p>{p.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===================== TECH ===================== -->
  <section class="section" id="tech">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">TECHNOLOGY</span>
        <h2>対応技術</h2>
        <p class="lead">幅広い技術スタックに対応します（一例）。</p>
      </div>
      <div class="tech-cards">
        {TECH_GROUPS.map((g, i) => (
          <div class="tech-card reveal" data-delay={i % 3}>
            <div class="tc-head">
              <span class="tc-icon"><Icon name={g.icon} size={24} /></span>
              <h3 class="tc-title">{g.category}</h3>
            </div>
            <div class="tg-chips">
              {g.items.map((t) => <span class="tech-chip">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== COMPANY ===================== -->
  <section class="section section--soft" id="company">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">COMPANY</span>
        <h2>会社情報</h2>
      </div>
      <div class="company-grid">
        <div class="company-wrap reveal">
          <table class="company-table">
            <tbody>
              {companyRows.map((r) => (
                <tr><th scope="row">{r.th}</th><td>{r.td}</td></tr>
              ))}
            </tbody>
          </table>
          <p class="company-more">
            <a href={url('/company/history/')} class="btn btn--grad">会社沿革を見る<Icon name="arrow" size={18} /></a>
          </p>
        </div>
        <aside class="access-card reveal" data-delay="1">
          <h3><Icon name="map" size={20} /> アクセス</h3>
          <p class="ac-addr">〒{COMPANY.postalCode}<br />{COMPANY.addressLine1}<br />{COMPANY.addressLine2}</p>
          <p class="ac-note">{COMPANY.access}</p>
          <div class="ac-map">
            <iframe
              src={mapEmbed}
              title={`${COMPANY.name} 所在地の地図`}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>
          </div>
          <a href={mapLink} target="_blank" rel="noopener" class="ac-maplink">
            <Icon name="map" size={16} /> Googleマップで開く
          </a>
          <a href={`tel:${COMPANY.tel.replaceAll('-', '')}`} class="ac-tel"><Icon name="phone" size={18} /> {COMPANY.tel}</a>
        </aside>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---- hero ---- */
  .hero {
    position: relative;
    padding-top: calc(var(--header-h) + clamp(50px, 8vw, 90px));
    padding-bottom: clamp(60px, 9vw, 100px);
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    width: 760px;
    height: 760px;
    right: -220px;
    top: -280px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, rgba(152, 199, 39, 0.2), transparent 60%),
      radial-gradient(circle at 70% 70%, rgba(42, 134, 192, 0.26), transparent 62%);
    z-index: 0;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 50px;
    align-items: center;
  }
  .hero h1 {
    font-size: clamp(2.3rem, 5.6vw, 3.7rem);
    line-height: 1.18;
    letter-spacing: -0.02em;
    margin: 22px 0 0;
  }
  .hero-lead {
    margin-top: 22px;
    font-size: clamp(1rem, 2vw, 1.12rem);
    color: var(--muted);
    max-width: 520px;
  }
  .hero-actions {
    margin-top: 32px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .hero-mini {
    list-style: none;
    margin: 32px 0 0;
    padding: 0;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    font-size: 0.86rem;
    color: var(--muted);
  }
  .hero-mini li { display: inline-flex; align-items: center; gap: 7px; }
  .hero-mini b { color: var(--ink); }
  .hero-mini :global(svg) { color: var(--green-d); }
  @media (max-width: 980px) {
    .hero-inner { grid-template-columns: 1fr; gap: 30px; }
    .hero-mini { gap: 18px; }
  }

  /* ---- stats ---- */
  .stats { background: var(--navy); color: #fff; }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    padding-block: clamp(36px, 5vw, 52px);
  }
  .stat { padding: 6px 24px; }
  .stat:not(:last-child) { border-right: 1px solid rgba(255, 255, 255, 0.08); }
  .stat .n { font-size: clamp(1.9rem, 4vw, 2.6rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.1; }
  .stat .n em { font-style: normal; font-size: 0.5em; color: #9fb4c4; margin-left: 4px; }
  .stat .l { font-size: 0.7rem; letter-spacing: 0.2em; color: #7e94a6; margin-top: 6px; font-weight: 700; }
  .stat .note { font-size: 0.8rem; color: #b9c8d4; margin-top: 2px; }
  @media (max-width: 720px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 24px 0; }
    .stat:nth-child(2) { border-right: none; }
  }

  /* ---- about ---- */
  .about-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  .about-art-wrap { max-width: 480px; }
  .about-copy h2 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin: 0.4em 0 0.6em; }
  .about-copy p { color: var(--ink-soft); }
  .about-points {
    margin-top: 1.8em;
    display: grid;
    gap: 14px;
  }
  .about-points div {
    display: flex;
    flex-direction: column;
    padding-left: 18px;
    border-left: 3px solid;
    border-image: var(--grad) 1;
  }
  .about-points b { color: var(--ink); }
  .about-points span { font-size: 0.9rem; color: var(--muted); }
  .about-more { margin-top: 1.8em; }
  @media (max-width: 880px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-art-wrap { order: 2; margin-inline: auto; }
  }

  /* ---- philosophy（会社理念） ---- */
  .philosophy-list {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 860px;
    display: grid;
    gap: 18px;
  }
  .philosophy-item {
    display: flex;
    align-items: center;
    gap: 22px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 26px 30px;
    box-shadow: var(--shadow-sm);
  }
  .ph-num {
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1;
    flex: none;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .ph-body h3 {
    font-size: 1.12rem;
    color: var(--blue-d);
    margin-bottom: 0.35em;
  }
  .ph-body p {
    margin: 0;
    color: var(--ink-soft);
    font-weight: 500;
    font-size: 0.97rem;
    line-height: 1.8;
  }
  @media (max-width: 560px) {
    .philosophy-item { gap: 16px; padding: 20px 22px; }
    .ph-body p { font-size: 0.92rem; }
  }

  /* ---- message（代表ごあいさつ） ---- */
  .message-grid {
    display: grid;
    grid-template-columns: 0.72fr 1.28fr;
    gap: clamp(28px, 4vw, 52px);
    align-items: center;
    max-width: 1040px;
    margin-inline: auto;
  }
  /* 図を枠なしにしたため、文章側も枠を設けずプレーンに配置（左右のバランスを取る） */
  .message-card {
    position: relative;
    padding-top: clamp(28px, 4vw, 40px);
  }
  .message-card::before {
    content: "“";
    position: absolute;
    top: -0.18em;
    left: -0.06em;
    font-size: 3.6rem;
    line-height: 1;
    color: var(--blue-soft);
    font-family: Georgia, serif;
  }
  .message-card p {
    color: var(--ink-soft);
    line-height: 2;
    position: relative;
  }
  .message-card p:last-of-type { margin-bottom: 0; }
  .message-sign {
    text-align: right;
    margin-top: 1.6em !important;
    color: var(--ink);
  }
  .message-sign strong {
    font-size: 1.2rem;
    letter-spacing: 0.06em;
    margin-left: 0.3em;
  }
  @media (max-width: 880px) {
    .message-grid { grid-template-columns: 1fr; gap: 28px; }
    .message-figure { max-width: 340px; margin-inline: auto; }
  }

  /* ---- services ---- */
  .service-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 34px 30px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: #d6e6f2;
  }
  .svc-no { font-size: 0.8rem; font-weight: 800; color: var(--green-d); letter-spacing: 0.1em; }
  .svc-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 18px;
    background: var(--grad);
    color: #fff;
    margin: 12px 0 18px;
  }
  .service-card h3 { font-size: 1.3rem; }
  .svc-en { font-size: 0.72rem; color: #9aa9b7; letter-spacing: 0.12em; font-weight: 700; margin-top: 3px; }
  .service-card > p { color: var(--muted); font-size: 0.95rem; margin-top: 14px; }
  .service-card ul {
    margin: 18px 0 0;
    padding: 16px 0 0;
    list-style: none;
    border-top: 1px dashed var(--line);
  }
  .service-card li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 9px;
    color: var(--ink-soft);
    font-size: 0.9rem;
  }
  .service-card li::before {
    content: "";
    position: absolute;
    left: 0; top: 7px;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: rgba(152, 199, 39, 0.18);
  }
  .service-card li::after {
    content: "";
    position: absolute;
    left: 5px; top: 10px;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--green-d);
  }

  /* ---- strengths ---- */
  .strength-card {
    padding: 36px 30px;
    border-radius: var(--radius-lg);
    background: #fff;
    border: 1px solid var(--line);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .strength-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .st-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px; height: 56px;
    border-radius: 16px;
    background: var(--blue-soft);
    color: var(--blue);
    margin-bottom: 18px;
  }
  .strength-card h3 { font-size: 1.15rem; margin-bottom: 0.5em; }
  .strength-card p { color: var(--muted); font-size: 0.93rem; margin: 0; }

  /* ---- process ---- */
  .process {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
    counter-reset: step;
  }
  .process-step {
    position: relative;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 30px 24px;
  }
  .process-step:not(:last-child)::after {
    content: "";
    position: absolute;
    right: -16px; top: 50%;
    width: 16px; height: 2px;
    background: var(--line);
    z-index: 1;
  }
  .ps-no {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    border-radius: 12px;
    background: var(--grad);
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    margin-bottom: 14px;
  }
  .process-step h3 { font-size: 1.05rem; }
  .process-step p { color: var(--muted); font-size: 0.88rem; margin: 0.5em 0 0; }
  @media (max-width: 880px) {
    .process { grid-template-columns: repeat(2, 1fr); }
    .process-step:nth-child(2)::after { display: none; }
  }
  @media (max-width: 520px) {
    .process { grid-template-columns: 1fr; }
    .process-step::after { display: none !important; }
  }

  /* ---- tech (カテゴリ別) ---- */
  .tech-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 2vw, 24px);
  }
  .tech-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 26px 26px 24px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .tech-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: #d6e6f2;
  }
  .tc-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }
  .tc-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex: none;
    border-radius: 12px;
    background: var(--grad);
    color: #fff;
  }
