---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { COMPANY, CULTURE, IDEAL, JOB_OPENINGS, RECRUIT_CONTACT } from '../../data/site';
import { url } from '../../utils/url';
import Breadcrumb from '../../components/Breadcrumb.astro';

// 募集要項の各表を、連絡先・オンライン応募の行も含めて事前にHTML化（テンプレート内の
// 入れ子式を避けて確実にビルドできるようにする）
const telHref = 'tel:' + RECRUIT_CONTACT.tel.replaceAll('-', '');
const contactHtml =
  `TEL：<a href="${telHref}">${RECRUIT_CONTACT.tel}</a><br>` +
  `Mail：<a href="mailto:${RECRUIT_CONTACT.email}">${RECRUIT_CONTACT.email}</a>`;
const applyHtml =
  `<a class="btn btn--grad btn--sm" href="${url('/recruit_top/subscription/')}">オンライン応募ページへ →</a>`;

const jobs = JOB_OPENINGS.map((job) => ({
  id: job.id,
  label: job.label,
  rows: [
    ...job.rows.map((r) => ({ th: r.th, html: r.td.split('\n').join('<br>') })),
    { th: '連絡先', html: contactHtml },
    { th: 'オンライン応募', html: applyHtml },
  ],
}));
---

<Base title="採用情報" path="/recruit_top/" description="株式会社オアシス情報システムズの採用情報。一緒に未来をつくる仲間を募集しています。">
  <section class="page-hero">
    <div class="container inner">
      <span class="en">RECRUIT</span>
      <h1>採用情報</h1>
    </div>
  </section>

  <div class="container">
    <Breadcrumb items={[{ label: 'ホーム', href: '/' }, { label: '採用情報' }]} />
  </div>

  <!-- message -->
  <section class="section" style="padding-top: clamp(24px, 4vw, 44px)">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">MESSAGE</span>
        <h2>一緒に、未来をつくりませんか</h2>
        <p class="lead">
          私たちは、確かな技術と人の力でお客様のビジネスを支えています。<br />
          新しい仲間として、あなたの力を発揮してください。
        </p>
        <p class="recruit-types reveal">
          <a href="#requirements" data-job="career">キャリア採用</a>
          <a href="#requirements" data-job="newgrad">新卒採用</a>
        </p>
      </div>
    </div>
  </section>

  <!-- culture -->
  <section class="section section--soft" style="padding-top: clamp(40px, 6vw, 70px)">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">CULTURE</span>
        <h2>働く環境</h2>
      </div>
      <div class="grid grid-3">
        {CULTURE.map((c, i) => (
          <div class="culture-card reveal" data-delay={i}>
            <span class="cc-icon"><Icon name={c.icon} size={26} /></span>
            <h3>{c.title}</h3>
            <p>{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 求める人物像 -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">IDEAL CANDIDATE</span>
        <h2>求める人物像</h2>
        <p class="lead">スキルや経験はもちろん、こんな想いを持った方をお待ちしています。</p>
      </div>
      <ul class="ideal-list">
        {IDEAL.map((t) => (
          <li class="ideal-item reveal">
            <span class="ideal-check"><Icon name="check" size={18} /></span>
            <span>{t}</span>
          </li>
        ))}
      </ul>
      <p class="ideal-note reveal">
        ※ 未経験の方や、これから挑戦したい方も歓迎します。まずはお気軽にご応募・ご相談ください。
      </p>
    </div>
  </section>

  <!-- 募集要項 -->
  <section class="section section--soft" id="requirements">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">REQUIREMENTS</span>
        <h2>募集要項</h2>
        <p class="lead">キャリア採用・新卒採用ともに募集しています。タブで切り替えてご覧ください。</p>
      </div>

      <div class="job-tabs reveal">
        {jobs.map((job, i) => (
          <input type="radio" name="job-tab" id={`job-${job.id}`} checked={i === 0} />
        ))}
        <div class="job-tablist" role="tablist">
          {jobs.map((job) => (
            <label class="job-tab" for={`job-${job.id}`}>{job.label}</label>
          ))}
        </div>
        <div class="job-panels">
          {jobs.map((job) => (
            <div class={`job-panel job-panel-${job.id}`}>
              <table class="job-table">
                <tbody>
                  {job.rows.map((r) => (
                    <tr>
                      <th scope="row">{r.th}</th>
                      <td set:html={r.html}></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ))}
        </div>
      </div>
      <p class="job-note reveal">※ 記載の条件は募集時点のものです。最新の募集状況は、オンライン応募またはお問い合わせよりご確認ください。</p>
    </div>
  </section>

  <!-- apply -->
  <section class="section">
    <div class="container">
      <div class="apply-box reveal">
        <div class="apply-text">
          <span class="eyebrow">ENTRY</span>
          <h2>ご応募について</h2>
          <p>
            ご応募はオンライン応募フォームより受け付けております。<br />
            ご記入いただいた個人情報は、採用選考の目的にのみ利用いたします。
          </p>
          <p class="apply-note">
            個人情報の取り扱いについては
            <a href={url('/privacy/')}>個人情報保護方針</a> および
            <a href={url('/docs/recruit-privacy.pdf')} target="_blank" rel="noopener">採用応募時の個人情報の取扱い（PDF）</a>
            をご確認ください。
          </p>
        </div>
        <div class="apply-actions">
          <a href={url('/recruit_top/subscription/')} class="btn btn--grad">オンライン応募へ<Icon name="arrow" size={18} /></a>
          <a href={`tel:${RECRUIT_CONTACT.tel.replaceAll('-', '')}`} class="apply-tel">
            <Icon name="phone" size={18} /> {RECRUIT_CONTACT.tel}
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .culture-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 34px 30px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .culture-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .cc-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px; height: 56px;
    border-radius: 16px;
    background: var(--grad);
    color: #fff;
    margin-bottom: 18px;
  }
  .culture-card h3 { font-size: 1.15rem; margin-bottom: 0.5em; }
  .culture-card p { color: var(--muted); font-size: 0.93rem; margin: 0; }

  .recruit-types {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 1.4em;
  }
  .recruit-types a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--blue-soft);
    color: var(--blue-d);
    border: 1px solid #d9ecf7;
    border-radius: 999px;
    padding: 9px 24px;
    font-weight: 700;
    font-size: 0.92rem;
    transition: background 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }
  .recruit-types a::after {
    content: "↓";
    font-size: 0.85em;
    opacity: 0.7;
  }
  .recruit-types a:hover {
    background: var(--blue);
    color: #fff;
    transform: translateY(-2px);
  }

  /* 求める人物像 */
  .ideal-list {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 760px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .ideal-item {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px 22px;
    font-weight: 600;
    color: var(--ink);
    box-shadow: var(--shadow-sm);
  }
  .ideal-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    flex: none;
    border-radius: 50%;
    background: var(--grad);
    color: #fff;
  }
  .ideal-note {
    max-width: 760px;
    margin: 1.4em auto 0;
    text-align: center;
    color: var(--muted);
    font-size: 0.88rem;
  }
  @media (max-width: 640px) {
    .ideal-list { grid-template-columns: 1fr; }
  }

  /* 募集要項（タブ切替・CSSのみ） */
  .job-tabs {
    max-width: 840px;
    margin: 0 auto;
  }
  .job-tabs > input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .job-tablist {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-bottom: 26px;
  }
  .job-tab {
    cursor: pointer;
    padding: 12px 30px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--muted);
    background: #fff;
    border: 1px solid var(--line);
    transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }
  .job-tab:hover {
    color: var(--blue);
  }
  .job-panel {
    display: none;
  }
  #job-career:checked ~ .job-tablist label[for='job-career'],
  #job-newgrad:checked ~ .job-tablist label[for='job-newgrad'] {
    background: var(--grad);
    color: #fff;
    border-color: transparent;
  }
  #job-career:checked ~ .job-panels .job-panel-career,
  #job-newgrad:checked ~ .job-panels .job-panel-newgrad {
    display: block;
  }
  .job-table {
    width: 100%;
    border-collapse: collapse;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .job-table th,
  .job-table td {
    border-bottom: 1px solid var(--line);
    padding: 16px 20px;
    text-align: left;
    vertical-align: top;
    font-size: 0.94rem;
    line-height: 1.8;
  }
  .job-table tr:last-child th,
  .job-table tr:last-child td {
    border-bottom: none;
  }
  .job-table th {
    width: 28%;
    background: var(--soft);
    color: var(--blue-d);
    font-weight: 700;
    white-space: nowrap;
  }
  .job-table td {
    color: var(--ink-soft);
  }
  .job-note {
    max-width: 840px;
    margin: 1.4em auto 0;
    color: var(--muted);
    font-size: 0.85rem;
    text-align: center;
  }
  @media (max-width: 600px) {
    .job-table th {
      width: 36%;
      white-space: normal;
    }
    .job-table th,
    .job-table td {
      padding: 12px 14px;
      font-size: 0.9rem;
    }
  }

  .apply-box {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(28px, 4vw, 52px);
    align-items: center;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    padding: clamp(34px, 5vw, 56px);
    box-shadow: var(--shadow-sm);
  }
  .apply-text h2 { font-size: 1.6rem; margin: 0.4em 0 0.6em; }
  .apply-text p { color: var(--ink-soft); }
  .apply-note { font-size: 0.86rem; color: var(--muted); }
  .apply-actions { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
  .apply-tel {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--ink);
  }
  .apply-tel :global(svg) { color: var(--green-d); }
  @media (max-width: 760px) {
    .apply-box { grid-template-columns: 1fr; }
  }
</style>

<script>
  // MESSAGE下のボタン → 募集要項の該当タブを表示してスクロール
  document.querySelectorAll('.recruit-types a[data-job]').forEach((a) => {
    a.addEventListener('click', () => {
      const radio = document.getElementById('job-' + a.getAttribute('data-job')) as HTMLInputElement | null;
      if (radio) radio.checked = true;
    });
  });
</script>
